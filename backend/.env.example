# Example backend environment only. Never commit real Supabase secrets.
APP_NAME=greencard-api
APP_ENV=development
APP_VERSION=dev
PORT=8080
LOG_LEVEL=debug
ENABLE_SEEDED_ACCOUNT_FALLBACK=false
ENABLE_TRANSACTION_SIMULATION=true
WORKER_ENABLED=false
WORKER_ENABLE_SIMULATION_PROGRESSION=true
WORKER_POLL_INTERVAL=15s
WORKER_BATCH_SIZE=100
WORKER_JOB_LOCK_TTL=2m
WORKER_MAX_ATTEMPTS=5
WORKER_RECONCILIATION_AGE=2m
WORKER_RETRY_EVALUATION_AGE=2m
WORKER_FUNDING_PENDING_TIMEOUT=15m
WORKER_TRANSFER_CONVERTING_TIMEOUT=20m
WORKER_PAYMENT_SUBMITTED_TIMEOUT=10m
WORKER_PAYMENT_UNDER_REVIEW_TIMEOUT=20m
WORKER_PAYMENT_PROCESSING_TIMEOUT=30m
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_PROXY_HEADERS=false
RATE_LIMIT_GLOBAL_REQUESTS=300
RATE_LIMIT_GLOBAL_WINDOW=1m
RATE_LIMIT_AUTHENTICATED_REQUESTS=900
RATE_LIMIT_AUTHENTICATED_WINDOW=1m
RATE_LIMIT_SENSITIVE_REQUESTS=20
RATE_LIMIT_SENSITIVE_WINDOW=1m
RATE_LIMIT_WEBHOOK_REQUESTS=120
RATE_LIMIT_WEBHOOK_WINDOW=1m

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_PROFILE_TABLE=profiles
SUPABASE_ACCOUNT_TABLE=accounts
SUPABASE_ACTIVITY_TABLE=activities
SUPABASE_BALANCE_MOVEMENT_TABLE=account_balance_movements
SUPABASE_AUDIT_LOG_TABLE=audit_logs
SUPABASE_WEBHOOK_EVENT_TABLE=provider_webhook_events
SUPABASE_FUNDING_TABLE=funding_transactions
SUPABASE_TRANSFER_TABLE=transfer_transactions
SUPABASE_PAYMENT_TABLE=payment_transactions
SUPABASE_IDEMPOTENCY_TABLE=idempotency_keys
SUPABASE_RECIPIENT_TABLE=recipients
SUPABASE_SUPPORT_TICKET_TABLE=support_tickets
SUPABASE_SUPPORT_MESSAGE_TABLE=support_ticket_messages

HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
SUPABASE_AUTH_TIMEOUT=5s
SUPABASE_JWKS_CACHE_TTL=10m
SUPABASE_REST_TIMEOUT=5s
WEBHOOK_SIGNATURE_TOLERANCE=5m
WEBHOOK_SANDBOXPAY_SECRET=replace-with-long-random-secret

KYC_PROVIDER=disabled
SMILE_ID_ENVIRONMENT=sandbox
SMILE_ID_PARTNER_ID=your-smile-id-partner-id
SMILE_ID_API_KEY=your-smile-id-api-key
SMILE_ID_BASE_URL=
SMILE_ID_SOURCE_SDK_VERSION=greencard-go-1.0
SMILE_ID_TIMEOUT=10s
